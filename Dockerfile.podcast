# Dockerfile.podcast — reference Dockerfile

FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .

ENV NODE_ENV=production
RUN mkdir -p /tmp/podcast_master

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s CMD node -e "console.log('ok')"

CMD ["node", "server.js"]
